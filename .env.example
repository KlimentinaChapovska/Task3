# Copy this file to .env and fill in any values required for your environment.
# This project currently requires NO secret API keys (Open-Meteo is free & keyless).

# --- Backend CORS ---
# Comma-separated list of allowed frontend origins.
# For local development the default value in backend/main.py is used.
# For production (VPS) set this in docker-compose.yml or your server env.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Future use ---
# If you add an API key-based service later, add its variable here.
# SOME_API_KEY=your_key_here
